# DigitalBevy Environment Configuration
# This file is a REFERENCE TEMPLATE only
# The deploy.sh script will create the actual .env file automatically

# ==========================================================
# IMPORTANT: DO NOT commit real credentials to version control
# The deploy.sh script will:
#   - Ask for all configuration interactively
#   - Generate secure JWT_SECRET and ENCRYPTION_KEY
#   - Create the .env file with your inputs
# ==========================================================

# Server Configuration
PORT=3026
NODE_ENV=development

# ==========================================================
# DATABASE CONFIGURATION
# ==========================================================
# Choose ONE of the following database configurations:

# OPTION 1: MySQL
DATABASE_URL="mysql://root:rootpassword@localhost:3306/repdtb"

# OPTION 2: PostgreSQL
# DATABASE_URL="postgresql://username:password@localhost:5432/databasename"

# ==========================================================
# SECURITY KEYS
# ==========================================================
# IMPORTANT: Never use these placeholder values in production!
# Generate secure keys with: openssl rand -hex 32
# The deploy.sh script will generate these automatically

JWT_SECRET=your_64_character_jwt_secret_here_generate_with_openssl_rand_hex_32
ENCRYPTION_KEY=your_64_character_encryption_key_here_generate_with_openssl_rand_hex_32

# ==========================================================
# SCHEDULER CONFIGURATION
# ==========================================================
# Ringless Voicemail Scheduler (DropCowboy)
CRON_SCHEDULE=0 2 * * *
ENABLE_SCHEDULER=true

# Mautic Synchronization Scheduler
MAUTIC_SYNC_SCHEDULE=0 3 * * *
ENABLE_MAUTIC_SCHEDULER=true

# ==========================================================
# FRONTEND URL
# ==========================================================
# Used for email links and redirects
# Example: https://yoursite.com or http://localhost:3026
FRONTEND_URL=https://yoursite.com
